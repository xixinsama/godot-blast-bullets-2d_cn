<?xml version="1.0" encoding="UTF-8" ?>
<class name="BlockBulletsData2D" inherits="MultiMeshBulletsData2D" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/godotengine/godot/master/doc/class.xsd">
	<brief_description>
		包含[BlockBullets2D]的生成数据。
	</brief_description>
	<description>
		确保设置了[member MultiMeshBulletsData2D.transforms]属性。
		有关其余属性，请查看[MultiMeshBulletsData2D]的文档。
	</description>
	<tutorials>
	</tutorials>
	<members>
		<member name="block_rotation_radians" type="float" setter="set_block_rotation_radians" getter="get_block_rotation_radians" default="0.0">
			决定子弹块的移动方向。
		</member>
		<member name="block_speed" type="BulletSpeedData2D" setter="set_block_speed" getter="get_block_speed">
			这是子弹块使用的速度数据。
		</member>
	</members>
</class>
